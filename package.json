{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "renai-skills",
  "description": "Ren skills, plugins, and registry data",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "typecheck": "bun run --cwd schemas typecheck && bun run --cwd cli typecheck",
    "test": "bun run --cwd schemas test && bun run --cwd cli test",
    "validate": "bun cli/src/index.ts validate",
    "check": "bun cli/src/index.ts check",
    "build": "bun cli/src/index.ts build",
    "release": "bun cli/src/index.ts release",
    "publish:registry": "bun cli/src/index.ts publish"
  },
  "workspaces": ["cli", "schemas"],
  "catalog": {
    "@renai-labs/sdk": "0.1.3",
    "@tsconfig/bun": "1.0.9",
    "@types/bun": "1.3.11",
    "@types/semver": "7.5.8",
    "commander": "12.1.0",
    "gray-matter": "4.0.3",
    "picocolors": "1.1.1",
    "semver": "7.6.3",
    "typescript": "5.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
