{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "org": {
          "type": "string",
          "description": "Org display name."
        },
        "orgId": {
          "type": "string",
          "pattern": "^[a-z]+_[A-Za-z0-9]+$",
          "description": "Ren org id (org_…) this spec provisions into."
        },
        "ownerUserId": {
          "description": "Ren user id (usr_…) of the onboarding owner.",
          "type": "string",
          "pattern": "^[a-z]+_[A-Za-z0-9]+$"
        },
        "specVersion": {
          "description": "Semver of this spec document.",
          "type": "string"
        },
        "snapshotDate": {
          "description": "Date this spec was generated from live state.",
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "org",
        "orgId"
      ],
      "additionalProperties": false
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+_[A-Za-z0-9]+$",
            "description": "A live Ren entity id (e.g. pod_…, prj_…, agt_…). Pins the spec entry to an existing row."
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
          },
          "name": {
            "type": "string"
          },
          "model": {
            "type": "string",
            "description": "Ren model id, e.g. opus-4-8, sonnet-4-6, haiku-4-5."
          },
          "scope": {
            "type": "string",
            "enum": [
              "org",
              "user",
              "registry"
            ],
            "description": "Visibility tier. Pods/projects/entities are created with the matching scope flag."
          },
          "icon": {
            "description": "Logo URL, for rendering.",
            "type": "string"
          },
          "promptRef": {
            "description": "Pointer to the agent's system prompt (not inlined here).",
            "type": "string"
          },
          "skills": {
            "description": "Skill slugs attached to this agent.",
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$",
              "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
            }
          },
          "mcps": {
            "description": "MCP slugs wired to this agent.",
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$",
              "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "slug",
          "name"
        ],
        "additionalProperties": false
      }
    },
    "mcps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+_[A-Za-z0-9]+$",
            "description": "A live Ren entity id (e.g. pod_…, prj_…, agt_…). Pins the spec entry to an existing row."
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
          },
          "name": {
            "type": "string"
          },
          "registrySlug": {
            "description": "Slug in the Ren MCP registry, if a registry MCP.",
            "type": "string"
          },
          "remoteUrl": {
            "description": "For a custom (non-registry) remote MCP server.",
            "type": "string",
            "format": "uri"
          },
          "auth": {
            "type": "string",
            "enum": [
              "oauth",
              "basic",
              "api_key",
              "none"
            ]
          },
          "credential": {
            "description": "Slug of the credential this MCP needs.",
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "icon": {
            "description": "Logo URL, for rendering.",
            "type": "string"
          },
          "tags": {
            "description": "Tag names, for rendering / filtering.",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "slug",
          "name"
        ],
        "additionalProperties": false
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+_[A-Za-z0-9]+$",
            "description": "A live Ren entity id (e.g. pod_…, prj_…, agt_…). Pins the spec entry to an existing row."
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
          },
          "source": {
            "type": "string",
            "enum": [
              "registry",
              "org",
              "user"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "slug"
        ],
        "additionalProperties": false
      }
    },
    "credentials": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+_[A-Za-z0-9]+$",
            "description": "A live Ren entity id (e.g. pod_…, prj_…, agt_…). Pins the spec entry to an existing row."
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
          },
          "provider": {
            "type": "string",
            "description": "What the credential is for, e.g. \"github\", \"apollo\"."
          },
          "authType": {
            "type": "string",
            "enum": [
              "oauth",
              "basic",
              "api_key",
              "env"
            ]
          },
          "vault": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Slug of the vault this credential lives in."
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "slug",
          "provider",
          "vault"
        ],
        "additionalProperties": false
      }
    },
    "vaults": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+_[A-Za-z0-9]+$",
            "description": "A live Ren entity id (e.g. pod_…, prj_…, agt_…). Pins the spec entry to an existing row."
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
          },
          "name": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "enum": [
              "org",
              "user",
              "registry"
            ],
            "description": "Visibility tier. Pods/projects/entities are created with the matching scope flag."
          },
          "attachedPods": {
            "description": "Slugs of pods this vault attaches to.",
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$",
              "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "slug",
          "name",
          "scope"
        ],
        "additionalProperties": false
      }
    },
    "fileStores": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+_[A-Za-z0-9]+$",
            "description": "A live Ren entity id (e.g. pod_…, prj_…, agt_…). Pins the spec entry to an existing row."
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
          },
          "name": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "enum": [
              "org",
              "user",
              "registry"
            ],
            "description": "Visibility tier. Pods/projects/entities are created with the matching scope flag."
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "slug",
          "name",
          "scope"
        ],
        "additionalProperties": false
      }
    },
    "memoryStores": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+_[A-Za-z0-9]+$",
            "description": "A live Ren entity id (e.g. pod_…, prj_…, agt_…). Pins the spec entry to an existing row."
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
          },
          "name": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "enum": [
              "org",
              "user",
              "registry"
            ],
            "description": "Visibility tier. Pods/projects/entities are created with the matching scope flag."
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "slug",
          "name",
          "scope"
        ],
        "additionalProperties": false
      }
    },
    "pods": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+_[A-Za-z0-9]+$",
            "description": "A live Ren entity id (e.g. pod_…, prj_…, agt_…). Pins the spec entry to an existing row."
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
          },
          "name": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "enum": [
              "org",
              "user",
              "registry"
            ],
            "description": "Visibility tier. Pods/projects/entities are created with the matching scope flag."
          },
          "vaults": {
            "description": "Slugs of vaults attached to this pod (priority order).",
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$",
              "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "slug",
          "name"
        ],
        "additionalProperties": false
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+_[A-Za-z0-9]+$",
            "description": "A live Ren entity id (e.g. pod_…, prj_…, agt_…). Pins the spec entry to an existing row."
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
          },
          "name": {
            "type": "string"
          },
          "pod": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Slug of the pod this project lives in."
          },
          "buildOrder": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "slackChannel": {
            "description": "Slack channel name this project maps to.",
            "type": "string"
          },
          "primaryAgent": {
            "description": "Slug of the project's primary agent.",
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "subAgents": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$",
              "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
            }
          },
          "fileStores": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$",
              "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
            }
          },
          "memoryStores": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$",
              "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
            }
          },
          "restricted": {
            "type": "boolean"
          },
          "requirements": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$",
                  "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "agent_attached",
                    "skill_attached",
                    "mcp_wired",
                    "credential_present",
                    "trigger_configured",
                    "slack_mapped",
                    "file_store_attached",
                    "memory_store_attached",
                    "vault_attached",
                    "capability",
                    "other"
                  ]
                },
                "must": {
                  "type": "string",
                  "description": "Plain-language statement of exactly what must be true."
                },
                "agent": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$",
                  "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
                },
                "mcp": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$",
                  "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
                },
                "skill": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$",
                  "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
                },
                "credential": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$",
                  "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
                },
                "trigger": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$",
                  "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
                },
                "vault": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$",
                  "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
                },
                "store": {
                  "description": "Slug of the file/memory store this requirement is about.",
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$"
                },
                "channel": {
                  "type": "string"
                },
                "blocking": {
                  "type": "boolean"
                },
                "reason": {
                  "type": "string"
                },
                "verify": {
                  "description": "Exact way to confirm it live via the ren CLI.",
                  "type": "string"
                },
                "blockedBy": {
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "must"
              ],
              "additionalProperties": false
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "slug",
          "name",
          "pod"
        ],
        "additionalProperties": false
      }
    },
    "slack": {
      "type": "object",
      "properties": {
        "workspace": {
          "type": "string"
        },
        "teamId": {
          "type": "string"
        },
        "installationId": {
          "type": "string"
        },
        "botUserId": {
          "type": "string"
        },
        "channels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Channel name including the leading #, e.g. \"#bugs\"."
              },
              "id": {
                "type": "string"
              },
              "project": {
                "anyOf": [
                  {
                    "type": "string",
                    "pattern": "^[a-z0-9][a-z0-9-]*$",
                    "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Slug of the project this channel maps to, or null if unmapped."
              }
            },
            "required": [
              "name",
              "project"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "channels"
      ],
      "additionalProperties": false
    },
    "github": {
      "type": "object",
      "properties": {
        "installationId": {
          "description": "Ren GitHub installation id (ghi_…).",
          "type": "string",
          "pattern": "^[a-z]+_[A-Za-z0-9]+$"
        },
        "repos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "The owner/repo the agent works in."
              },
              "project": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$",
                "description": "Slug of the project this repo is bound to."
              },
              "baseBranch": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "project"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "repos"
      ],
      "additionalProperties": false,
      "description": "GitHub repos bound to projects. Non-native to the upstream spec; a first-class Ren concept."
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+_[A-Za-z0-9]+$",
            "description": "A live Ren entity id (e.g. pod_…, prj_…, agt_…). Pins the spec entry to an existing row."
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Kebab-case slug used to reference an entity elsewhere in this spec."
          },
          "project": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Slug of the project whose primary agent this trigger fires."
          },
          "schedule": {
            "type": "string",
            "description": "Cron expression, e.g. \"0 9 * * 1\"."
          },
          "timezone": {
            "description": "IANA tz, e.g. \"Asia/Kolkata\".",
            "type": "string"
          },
          "inputMessage": {
            "type": "string",
            "description": "Fixed prompt delivered to the primary agent on each fire."
          },
          "enabled": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "slug",
          "project",
          "schedule",
          "inputMessage"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "meta",
    "agents",
    "pods",
    "projects"
  ],
  "additionalProperties": false,
  "$id": "https://renai.build/schemas/org-topology.draft.schema.json",
  "title": "Ren Org Topology (desired-state draft)",
  "description": "Desired-state draft of one Org's Ren topology, authored from an interview and reconciled against live state. Same shape as the live contract, but `id` is optional — entities are keyed by `slug` until provisioned, then their `id` is filled in."
}
